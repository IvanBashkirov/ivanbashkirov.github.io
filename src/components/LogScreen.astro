---
import { loadLog, loadProjects, monthLabel, fmtDate, fmtDay, type LogEntry, type Project } from '../lib/data';
import { getVisibleDocs, getAllDocs, docBySlug, type Doc } from '../lib/docs';
import DiskGlyph from './DiskGlyph.astro';

interface Props {
  active: 'activity' | 'projects' | 'writing';
}

const { active } = Astro.props;

const log = loadLog();
const projects = loadProjects();
const allDocs = await getAllDocs();
const visibleDocs = await getVisibleDocs();
const hiddenTune = allDocs.find((d) => d.data.hidden);

const TAGS: Record<string, string> = { ship: 'SHIP', txt: 'TXT', note: 'NOTE' };
const MODE_LABEL: Record<Props['active'], string> = {
  activity: 'LOG',
  projects: 'PROJ',
  writing: 'TXT',
};

/* The LOG view is one chronological stream: log entries, docs, projects.
   Projects only carry a year, so they sort to the top of that year. */
type FeedItem = { date: string; dateLabel: string; groupLabel: string } & (
  | { kind: 'log'; entry: LogEntry }
  | { kind: 'doc'; doc: Doc }
  | { kind: 'proj'; proj: Project }
);

const feed: FeedItem[] = [
  ...log.map((entry) => ({
    date: entry.date,
    dateLabel: fmtDay(entry.date),
    groupLabel: monthLabel(entry.date),
    kind: 'log' as const,
    entry,
  })),
  ...visibleDocs.map((doc) => ({
    date: doc.dateStr,
    dateLabel: fmtDay(doc.dateStr),
    groupLabel: monthLabel(doc.dateStr),
    kind: 'doc' as const,
    doc,
  })),
  ...projects.map((proj) => ({
    date: `${proj.year}-12-31`,
    dateLabel: proj.year,
    groupLabel: proj.year,
    kind: 'proj' as const,
    proj,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

const feedGroups: { label: string; items: FeedItem[] }[] = [];
for (const item of feed) {
  const last = feedGroups[feedGroups.length - 1];
  if (last && last.label === item.groupLabel) last.items.push(item);
  else feedGroups.push({ label: item.groupLabel, items: [item] });
}

const modeCounts = {
  activity: `${feed.length} ENTRIES`,
  projects: `${projects.length} CHANNELS`,
  writing: `${visibleDocs.length} DOCS`,
};

function projLinkLabel(link: string): string {
  if (link.startsWith('/doc/')) return 'post-mortem';
  if (link.startsWith('/')) return 'play';
  return 'visit';
}
---

<div class="statusbar" aria-hidden="true">
  <span id="statusMode">MODE: {MODE_LABEL[active]}</span>
  <span class="status-right">
    <span id="statusFlash"></span>
    <span id="statusInfo">{modeCounts[active]}</span>
  </span>
</div>

<!-- live operator status, fetched from Firestore at runtime -->
<div class="now-strip" id="nowStrip" hidden></div>

<section
  class="panel"
  id="panel-activity"
  aria-label="Log — everything"
  data-count={modeCounts.activity}
  data-static-entries={feed.length}
  hidden={active !== 'activity'}
>
  {feed.length === 0 && <p class="empty-state">LOG EMPTY · NOTHING HAS SHIPPED YET</p>}
  {
    feedGroups.map((g) => (
      <div class="month-group">
        <div class="month-divider" aria-hidden="true">
          {g.label}
        </div>
        <ol class="entries">
          {g.items.map((item) => {
            if (item.kind === 'log') {
              const e = item.entry;
              const doc = docBySlug(allDocs, e.doc);
              return (
                <li class="entry" data-type={e.type}>
                  <div class="meta">
                    <span class="e-date">{item.dateLabel}</span>
                    <span class={`tag tag-${e.type}`}>{TAGS[e.type]}</span>
                  </div>
                  <p class="line">{e.text}</p>
                  {doc && (
                    <a class="attach" href={doc.url} data-doc={doc.slug} data-kind={doc.data.kind}>
                      attached: “{doc.data.title}”<DiskGlyph />
                    </a>
                  )}
                </li>
              );
            }
            if (item.kind === 'doc') {
              const d = item.doc;
              return (
                <li class="entry" data-type="doc">
                  <div class="meta">
                    <span class="e-date">{item.dateLabel}</span>
                    <span class="tag tag-txt">DOC</span>
                  </div>
                  <p class="line">
                    <a class="attach" href={d.url} data-doc={d.slug} data-kind={d.data.kind}>
                      “{d.data.title}”<DiskGlyph />
                    </a>
                  </p>
                </li>
              );
            }
            const p = item.proj;
            return (
              <li class="entry" data-type="proj" data-status={p.status}>
                <div class="meta">
                  <span class="e-date">{item.dateLabel}</span>
                  <span class="tag tag-ship">PROJ</span>
                </div>
                <p class="line">
                  <b>{p.name}</b> — {p.desc}
                </p>
                {p.link && (
                  <a
                    class="attach"
                    href={p.link}
                    data-doc={p.link.startsWith('/doc/') ? p.link.split('/')[2] : undefined}
                    data-kind={p.link.startsWith('/doc/') ? 'essay' : undefined}
                  >
                    {projLinkLabel(p.link)}
                  </a>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    ))
  }
</section>

<section
  class="panel"
  id="panel-projects"
  aria-label="Projects"
  data-count={modeCounts.projects}
  hidden={active !== 'projects'}
>
  {projects.length === 0 && <p class="empty-state">NO CHANNELS PATCHED</p>}
  <ol class="channels">
    {
      projects.map((p) => (
        <li class="chan" data-status={p.status}>
          <span class="c-st">{p.status.toUpperCase()}</span>
          <div class="c-body">
            <h3>{p.name}</h3>
            {p.status === 'rec' && (
              <span class="vu" aria-hidden="true">
                <i /><i /><i />
              </span>
            )}
            <p class="c-desc">{p.desc}</p>
            {p.link && (
              <a
                class="attach"
                href={p.link}
                data-doc={p.link.startsWith('/doc/') ? p.link.split('/')[2] : undefined}
                data-kind={p.link.startsWith('/doc/') ? 'essay' : undefined}
              >
                {projLinkLabel(p.link)}
              </a>
            )}
          </div>
        </li>
      ))
    }
  </ol>
  <p class="legend">REC recording · OUT shipped · MUTE struck off · STBY standby</p>
</section>

<section
  class="panel"
  id="panel-writing"
  aria-label="Writing"
  data-count={modeCounts.writing}
  hidden={active !== 'writing'}
>
  <div class="diskbox-wrap">
    {visibleDocs.length === 0 && !hiddenTune && (
      <p class="empty-state">DISK BOX EMPTY · NO DOCS ON FILE</p>
    )}
    <ul class="diskbox" hidden={visibleDocs.length === 0 && !hiddenTune}>
      {
        visibleDocs.map((d) => (
          <li>
            <a class="disk" href={d.url} data-doc={d.slug} data-kind={d.data.kind}>
              <span class="label">
                <span class="d-title">{d.data.title}</span>
                <span class="d-meta">{fmtDate(d.dateStr)}</span>
              </span>
            </a>
          </li>
        ))
      }
      {
        hiddenTune && (
          <li id="hiddenDisk" hidden>
            <a
              class="disk"
              href={hiddenTune.url}
              data-doc={hiddenTune.slug}
              data-kind={hiddenTune.data.kind}
            >
              <span class="label">
                <span class="d-title">{hiddenTune.data.title}</span>
                <span class="d-meta">{fmtDate(hiddenTune.dateStr)}</span>
              </span>
            </a>
          </li>
        )
      }
    </ul>
  </div>
</section>
