---
import { render } from 'astro:content';
import { loadLog, loadProjects, groupByMonth, fmtDate, fmtDay } from '../lib/data';
import { getVisibleDocs, getAllDocs, docBySlug, type Doc } from '../lib/docs';
import DiskGlyph from './DiskGlyph.astro';

interface Props {
  active: 'activity' | 'projects' | 'writing';
}

const { active } = Astro.props;

const log = await loadLog();
const projects = await loadProjects();
const allDocs = await getAllDocs();
const visibleDocs = await getVisibleDocs();
const hiddenTune = allDocs.find((d) => d.data.hidden);

const months = groupByMonth(log);
const thoughts = visibleDocs.filter((d) => d.data.kind === 'thought');

const thoughtEntries = await Promise.all(
  thoughts.map(async (d) => ({ doc: d, Content: (await render(d)).Content }))
);
const thoughtMonths = groupByMonth(
  thoughtEntries.map((t) => ({ ...t, date: t.doc.dateStr }))
);

const TAGS: Record<string, string> = { ship: 'SHIP', txt: 'TXT', note: 'NOTE' };

const modeCounts = {
  activity: `${log.length} ENTRIES`,
  projects: `${projects.length} CHANNELS`,
  writing: `${visibleDocs.length} DOCS`,
};

function diskMeta(d: Doc): [string, string] {
  return [
    `DOC ${d.data.ref} · ${d.data.kind.toUpperCase()}`,
    `${fmtDate(d.dateStr)} · ${d.data.hidden ? '???' : d.sizeKB} KB`,
  ];
}

function projLinkLabel(link: string): string {
  if (link.startsWith('/doc/')) return 'post-mortem';
  if (link.startsWith('/')) return 'play';
  return 'visit';
}
---

<div class="statusbar" aria-hidden="true">
  <span id="statusMode">MODE: {active.toUpperCase()}</span>
  <span class="status-right">
    <span id="statusFlash"></span>
    <span id="statusInfo">{modeCounts[active]} · PWR ∞</span>
  </span>
</div>

<section
  class="panel"
  id="panel-activity"
  role="tabpanel"
  aria-labelledby="tab-activity"
  data-count={modeCounts.activity}
  hidden={active !== 'activity'}
>
  {log.length === 0 && <p class="empty-state">LOG EMPTY · NOTHING HAS SHIPPED YET · THE COUNTER IS WAITING</p>}
  {
    months.map((m) => (
      <div class="month-group">
        <div class="month-divider" aria-hidden="true">
          {m.label}
        </div>
        <ol class="entries">
          {m.items.map((e) => {
            const doc = docBySlug(allDocs, e.doc);
            return (
              <li class="entry" data-type={e.type}>
                <div class="meta">
                  <span class="e-date">{fmtDay(e.date)}</span>
                  <span class={`tag tag-${e.type}`}>{TAGS[e.type]}</span>
                  <span class="e-n">Nº {String(e.n).padStart(3, '0')}</span>
                </div>
                <p class="line">{e.text}</p>
                {doc && (
                  <a class="attach" href={doc.url} data-doc={doc.slug} data-kind={doc.data.kind}>
                    attached: “{doc.data.title}”<DiskGlyph />
                  </a>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    ))
  }
</section>

<section
  class="panel"
  id="panel-projects"
  role="tabpanel"
  aria-labelledby="tab-projects"
  data-count={modeCounts.projects}
  hidden={active !== 'projects'}
>
  <div class="month-divider" aria-hidden="true">CHANNELS</div>
  {projects.length === 0 && <p class="empty-state">NO CHANNELS PATCHED</p>}
  <ol class="channels">
    {
      projects.map((p) => (
        <li class="chan" data-status={p.status}>
          <span class="c-st">{p.status.toUpperCase()}</span>
          <div class="c-body">
            <h3>{p.name}</h3>
            {p.status === 'rec' && (
              <span class="vu" aria-hidden="true">
                <i /><i /><i />
              </span>
            )}
            <p class="c-desc">{p.desc}</p>
            {p.link && (
              <a
                class="attach"
                href={p.link}
                data-doc={p.link.startsWith('/doc/') ? p.link.split('/')[2] : undefined}
                data-kind={p.link.startsWith('/doc/') ? 'essay' : undefined}
              >
                {projLinkLabel(p.link)}
              </a>
            )}
          </div>
        </li>
      ))
    }
  </ol>
  <p class="legend">REC recording · OUT shipped · MUTE struck off · STBY standby</p>
</section>

<section
  class="panel"
  id="panel-writing"
  role="tabpanel"
  aria-labelledby="tab-writing"
  data-count={modeCounts.writing}
  hidden={active !== 'writing'}
>
  <div class="diskbox-wrap">
    <div class="diskbox-title" aria-hidden="true">DISK BOX</div>
    {visibleDocs.length === 0 && !hiddenTune && (
      <p class="empty-state">DISK BOX EMPTY · NO DOCS ON FILE</p>
    )}
    <ul class="diskbox" hidden={visibleDocs.length === 0 && !hiddenTune}>
      {
        visibleDocs.map((d) => {
          const [m1, m2] = diskMeta(d);
          return (
            <li>
              <a class="disk" href={d.url} data-doc={d.slug} data-kind={d.data.kind}>
                <span class="label">
                  <span class="d-title">{d.data.title}</span>
                  <span class="d-meta">
                    {m1}
                    <br />
                    {m2}
                  </span>
                </span>
              </a>
            </li>
          );
        })
      }
      {
        hiddenTune && (
          <li id="hiddenDisk" hidden>
            <a
              class="disk"
              href={hiddenTune.url}
              data-doc={hiddenTune.slug}
              data-kind={hiddenTune.data.kind}
            >
              <span class="label">
                <span class="d-title">{hiddenTune.data.title}</span>
                <span class="d-meta">
                  DOC ??? · TUNE
                  <br />
                  {fmtDate(hiddenTune.dateStr)} · ??? KB
                </span>
              </span>
            </a>
          </li>
        )
      }
    </ul>
  </div>

  <div class="thought-stream">
    {
      thoughtMonths.map((m) => (
        <div class="month-group">
          <div class="month-divider" aria-hidden="true">
            {m.label}
          </div>
          {m.items.map(({ doc, Content }) => (
            <article class="t-entry" data-type="txt">
              <div class="meta">
                <span class="e-date">{fmtDay(doc.dateStr)}</span>
                <span class="tag tag-note">THOUGHT</span>
              </div>
              <div class="t-body">
                <Content />
              </div>
            </article>
          ))}
        </div>
      ))
    }
  </div>
</section>
