---
import '@fontsource/doto/latin-700.css';
import '@fontsource/doto/latin-900.css';
import '@fontsource/fragment-mono/latin-400.css';
import '../styles/admin.css';
import { firebaseConfigured } from '../lib/firebase-config';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>IB-01 · SERVICE MODE</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#191919" />
  </head>
  <body data-configured={firebaseConfigured ? '1' : '0'}>
    <div class="svc">
      <header class="svc-head">
        <div class="svc-brand">
          <b>IB-01</b> SERVICE MODE
          <span class="svc-sub">AUTHORISED PERSONNEL ONLY · WARRANTY VOID IF SEAL BROKEN</span>
        </div>
        <div class="svc-session" id="sessionBox" hidden>
          <span class="svc-who" id="whoami"></span>
          <button class="btn btn-publish" id="publishBtn" title="Rebuild the public site from Firestore">
            <span class="led" id="publishLed"></span>PUBLISH
          </button>
          <button class="btn" id="signOutBtn">SIGN OUT</button>
        </div>
      </header>

      <!-- Firebase not configured yet -->
      <section class="card" id="notConfigured" hidden>
        <h2>NO UPLINK CONFIGURED</h2>
        <p>
          <code>firebase.config.json</code> still contains placeholder values. Create a Firebase
          project, then paste its web-app config into that file and redeploy. Full walkthrough:
          <code>FIREBASE-SETUP.md</code> in the repository root.
        </p>
      </section>

      <!-- Login gate -->
      <section class="card gate" id="gate" hidden>
        <h2>OPERATOR LOGIN</h2>
        <form id="loginForm">
          <label>EMAIL <input type="email" id="loginEmail" autocomplete="username" required /></label>
          <label>PASSWORD <input type="password" id="loginPassword" autocomplete="current-password" required /></label>
          <button class="btn btn-wide" type="submit">ENGAGE</button>
          <p class="err" id="loginErr" role="alert"></p>
        </form>
      </section>

      <!-- Publish panel -->
      <section class="card" id="publishPanel" hidden>
        <h2>PUBLISH — REBUILD PUBLIC SITE</h2>
        <p class="hint">
          Edits are saved to Firestore instantly, but the public site is static: publishing runs the
          GitHub Pages build so it re-renders from Firestore. Needs a fine-grained GitHub token with
          <b>Actions: read &amp; write</b> on this repository (stored only in this browser).
        </p>
        <div class="row">
          <label class="grow">GITHUB TOKEN <input type="password" id="ghToken" placeholder="github_pat_…" /></label>
          <button class="btn btn-wide" id="publishGo">RUN BUILD</button>
        </div>
        <p class="status" id="publishStatus"></p>
      </section>

      <!-- Console -->
      <main id="console" hidden>
        <nav class="tabs" role="tablist">
          <button class="tab active" data-tab="log" role="tab" aria-selected="true">LOG</button>
          <button class="tab" data-tab="docs" role="tab" aria-selected="false">DOCS</button>
          <button class="tab" data-tab="channels" role="tab" aria-selected="false">CHANNELS</button>
        </nav>

        <!-- LOG: quick-entry pad + entries -->
        <section class="pane" id="pane-log" role="tabpanel">
          <div class="card quickpad">
            <h2 id="logFormTitle">QUICK ENTRY</h2>
            <div class="seg" id="logType" role="radiogroup" aria-label="Entry type">
              <button class="seg-btn active" data-type="ship">SHIP</button>
              <button class="seg-btn" data-type="txt">TXT</button>
              <button class="seg-btn" data-type="note">NOTE</button>
            </div>
            <textarea id="logText" rows="3" placeholder="What shipped? One line, past tense, no excuses."></textarea>
            <div class="row">
              <label>DATE <input type="date" id="logDate" /></label>
              <label>Nº <input type="number" id="logN" min="1" class="narrow" /></label>
              <label class="grow">ATTACH DOC <select id="logDoc"><option value="">— NONE —</option></select></label>
            </div>
            <div class="row">
              <button class="btn btn-wide" id="logCommit">COMMIT ENTRY</button>
              <button class="btn" id="logCancelEdit" hidden>CANCEL EDIT</button>
              <span class="status" id="logStatus"></span>
            </div>
          </div>
          <ol class="list" id="logList"></ol>
        </section>

        <!-- DOCS: disk box + editor -->
        <section class="pane" id="pane-docs" role="tabpanel" hidden>
          <div id="docListView">
            <div class="row toolbar">
              <button class="btn btn-wide" id="docNew">+ NEW DOC</button>
            </div>
            <ol class="list" id="docList"></ol>
          </div>
          <div id="docEditView" hidden>
            <div class="card">
              <div class="row toolbar">
                <button class="btn" id="docBack">← DISK BOX</button>
                <span class="grow"></span>
                <button class="btn" id="docDelete">DELETE</button>
                <button class="btn btn-wide" id="docSave">SAVE DOC</button>
                <span class="status" id="docStatus"></span>
              </div>
              <div class="row">
                <label class="grow">TITLE <input type="text" id="docTitle" /></label>
                <label>SLUG <input type="text" id="docSlug" class="mid" /></label>
              </div>
              <div class="row">
                <label>REF <input type="text" id="docRef" class="narrow" /></label>
                <label>KIND
                  <select id="docKind">
                    <option value="essay">ESSAY</option>
                    <option value="thought">THOUGHT</option>
                    <option value="tune">TUNE</option>
                  </select>
                </label>
                <label>DATE <input type="date" id="docDate" /></label>
                <label>MIN <input type="number" id="docMinutes" min="1" class="narrow" placeholder="auto" /></label>
                <label class="check"><input type="checkbox" id="docHidden" /> HIDDEN</label>
              </div>
              <label class="block">STANDFIRST <input type="text" id="docStandfirst" /></label>
            </div>
            <div class="editor-split">
              <div class="editor-col">
                <div class="col-head">MARKDOWN <span id="docWords" class="dim"></span></div>
                <textarea id="docBody" spellcheck="false"></textarea>
              </div>
              <div class="editor-col">
                <div class="col-head">PREVIEW</div>
                <div class="preview doc-body" id="docPreview"></div>
              </div>
            </div>
          </div>
        </section>

        <!-- CHANNELS -->
        <section class="pane" id="pane-channels" role="tabpanel" hidden>
          <div class="card">
            <h2 id="chFormTitle">NEW CHANNEL</h2>
            <div class="row">
              <label>CH <input type="text" id="chCh" class="narrow" placeholder="01" /></label>
              <label class="grow">NAME <input type="text" id="chName" /></label>
              <label>STATUS
                <select id="chStatus">
                  <option value="rec">REC — recording</option>
                  <option value="out">OUT — shipped</option>
                  <option value="mute">MUTE — struck off</option>
                  <option value="stby">STBY — standby</option>
                </select>
              </label>
              <label>YEAR <input type="text" id="chYear" class="narrow" /></label>
            </div>
            <label class="block">DESC <textarea id="chDesc" rows="2"></textarea></label>
            <div class="row">
              <label class="grow">LINK <input type="text" id="chLink" placeholder="https://… or /doc/slug" /></label>
              <button class="btn btn-wide" id="chCommit">SAVE CHANNEL</button>
              <button class="btn" id="chCancelEdit" hidden>CANCEL</button>
              <span class="status" id="chStatusMsg"></span>
            </div>
          </div>
          <ol class="list" id="chList"></ol>
        </section>
      </main>

      <footer class="svc-foot">
        IB-01 SERVICE TERMINAL · CONTENT LIVES IN FIRESTORE · THE FRONT PANEL IS A STATIC RENDER
      </footer>
    </div>

    <script>
      import '../scripts/admin';
    </script>
  </body>
</html>
